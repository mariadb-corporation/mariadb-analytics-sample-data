#!/usr/bin/env bash

set -euo pipefail

# --- Configuration ---
SSL_CA=""
SCHEMA_DIR=$(readlink -f ./schema)
TMP_SPLIT_DIR="${SCHEMA_DIR}/flights_split"
DB_NAME='innodb_bts'
CS_DB_NAME='columnstore_bts'
MARIADB_BIN=$(which mariadb)
CPIMPORT_BIN=$(command -v cpimport || true)
CONN_FLAGS=("$@")
# Tunables for the parallel flights load. We pre-split flights.csv into NUM_CHUNKS
# files and feed at most MAX_PARALLEL of them to LOAD DATA LOCAL INFILE at a time.
NUM_CHUNKS=8
MAX_PARALLEL=4 # Adjust based on your Cloud Instance CPU/IO limits

GREEN='\033[0;32m'
RED='\033[0;31m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

get_filesize() {
    if stat -f%z "$1" >/dev/null 2>&1; then
        stat -f%z "$1" # BSD/macOS
    else
        stat -c%s "$1" # GNU/Linux
    fi
}

format_bytes() {
    local bytes=$1
    if command -v numfmt >/dev/null 2>&1; then
        numfmt --to=iec --suffix=B "$bytes"
    else
        awk -v bytes="$bytes" '
            BEGIN {
                split("B KiB MiB GiB TiB", units)
                size = bytes
                unit = 1
                while (size >= 1024 && unit < 5) {
                    size /= 1024
                    unit++
                }
                printf "%.1f%s", size, units[unit]
            }'
    fi
}

elapsed() {
    local start=$1
    local seconds=$(( $(date +%s) - start ))
    printf "%02d:%02d:%02d" $((seconds / 3600)) $(((seconds % 3600) / 60)) $((seconds % 60))
}

# --- Resilience ---
# Session-level timeouts: SkySQL/MaxScale defaults are short; large LOAD DATA streams need headroom.
INIT_CMD="SET SESSION net_read_timeout=3600, net_write_timeout=3600, wait_timeout=28800"
MAX_RETRIES=3
RETRY_BASE_DELAY=5

# retry <description> <cmd...>: re-runs the command up to MAX_RETRIES times with exponential backoff.
retry() {
    local desc=$1; shift
    local attempt=1 delay=$RETRY_BASE_DELAY rc=0
    while (( attempt <= MAX_RETRIES )); do
        if "$@"; then
            return 0
        fi
        rc=$?
        if (( attempt < MAX_RETRIES )); then
            echo -e "${YELLOW}${desc}: attempt ${attempt}/${MAX_RETRIES} failed (rc=${rc}), retrying in ${delay}s...${NC}" >&2
            sleep "$delay"
            delay=$((delay * 2))
        fi
        attempt=$((attempt + 1))
    done
    return "$rc"
}

# Wrappers so `retry` can re-execute commands that involve redirection / pipelines.
mariadb_file() {
    # mariadb_file <sql_file> [extra mariadb args...]
    local sql_file=$1; shift
    "$MARIADB_BIN" --local-infile=1 "${CONN_FLAGS[@]}" --init-command="$INIT_CMD" "$@" < "$sql_file"
}

load_small_table() {
    # load_small_table <table>
    local table=$1
    local sql="LOAD DATA LOCAL INFILE '${SCHEMA_DIR}/${table}.csv' INTO TABLE ${table} FIELDS TERMINATED BY ',' OPTIONALLY ENCLOSED BY '\"' LINES TERMINATED BY '\n' IGNORE 1 LINES;"
    "$MARIADB_BIN" --local-infile=1 "${CONN_FLAGS[@]}" --init-command="$INIT_CMD" --database="$DB_NAME" -e "$sql"
}

load_flights_chunk() {
    # load_flights_chunk <chunk_file>
    local file=$1
    "$MARIADB_BIN" --local-infile=1 "${CONN_FLAGS[@]}" --init-command="$INIT_CMD" --database="$DB_NAME" \
        -e "LOAD DATA LOCAL INFILE '${file}' INTO TABLE flights FIELDS TERMINATED BY ',' OPTIONALLY ENCLOSED BY '\"' LINES TERMINATED BY '\n' ${FLIGHTS_LOAD_COLUMNS};"
}

FLIGHTS_LOAD_COLUMNS="(\`year\`, \`month\`, \`day\`, \`day_of_week\`, \`fl_date\`, \`carrier\`, \`tail_num\`, \`fl_num\`, \`origin\`, \`dest\`, \`crs_dep_time\`, \`dep_time\`, \`dep_delay\`, \`taxi_out\`, \`wheels_off\`, \`wheels_on\`, \`taxi_in\`, \`crs_arr_time\`, \`arr_time\`, \`arr_delay\`, \`cancelled\`, \`cancellation_code\`, \`diverted\`, \`crs_elapsed_time\`, \`actual_elapsed_time\`, \`air_time\`, \`distance\`, \`carrier_delay\`, \`weather_delay\`, \`nas_delay\`, \`security_delay\`, \`late_aircraft_delay\`, @unused_trailing_field)"

if [ ${#CONN_FLAGS[@]} -eq 0 ]; then
    echo -e "${RED}Error: No connection flags provided.${NC}"
    exit 1
fi

# 1. Test Connection (fast pre-flight so we don't wait minutes on a silent TCP timeout)
echo -n "Testing connection... "
if CONN_ERR=$("$MARIADB_BIN" "${CONN_FLAGS[@]}" --connect-timeout=10 -e "SELECT 1" 2>&1 >/dev/null); then
    echo -e "${GREEN}ok${NC}"
else
    echo -e "${RED}failed${NC}"
    echo "$CONN_ERR"
    echo -e "${YELLOW}Common causes:${NC} client IP not allowlisted on the MariaDB Cloud instance, wrong host/port/credentials, or outbound ${YELLOW}3306${NC} blocked."
    exit 1
fi

# 2. Create Schema
echo "Creating schema on MariaDB Cloud..."
if retry "schema creation" mariadb_file "${SCHEMA_DIR}/innodb_schema.sql"; then
    echo -e "${GREEN}Schema creation successful.${NC}"
else
    echo -e "${RED}Schema creation failed after ${MAX_RETRIES} attempts.${NC}"
    exit 1
fi

# 1a. Detect Columnstore availability (cpimport binary + engine on server)
USE_COLUMNSTORE=0
CS_ENGINE_SUPPORT=$("$MARIADB_BIN" "${CONN_FLAGS[@]}" -N -B -e \
    "SELECT support FROM information_schema.engines WHERE engine='Columnstore'" 2>/dev/null || true)
if [[ -n "$CPIMPORT_BIN" && ( "$CS_ENGINE_SUPPORT" == "YES" || "$CS_ENGINE_SUPPORT" == "DEFAULT" ) ]]; then
    echo -e "${GREEN}Columnstore detected (cpimport: ${CPIMPORT_BIN}, server engine: ${CS_ENGINE_SUPPORT}).${NC}"
    printf "Also load '%s' via cpimport? (Y/N) " "$CS_DB_NAME"
    read -r LOAD_CS
    if [[ "$LOAD_CS" == [yY] ]]; then
        USE_COLUMNSTORE=1
    fi
else
    echo -e "${YELLOW}Skipping Columnstore (cpimport: ${CPIMPORT_BIN:-missing}, server engine: ${CS_ENGINE_SUPPORT:-absent}).${NC}"
fi

# 2. Download and Validate
for FILE in airports airlines flights; do
    CSV_PATH="${SCHEMA_DIR}/${FILE}.csv"
    if [[ ! -f "$CSV_PATH" ]]; then
        echo -e "${BLUE}Downloading ${FILE}.csv...${NC}"
        curl -o "$CSV_PATH" -# "https://sample-columnstore-data.s3.us-west-2.amazonaws.com/${FILE}.csv"
    else
        FILE_SIZE=$(get_filesize "$CSV_PATH")
        echo -e "${BLUE}Found ${FILE}.csv ($(format_bytes "$FILE_SIZE"))${NC}"
    fi
    FILE_SIZE=$(get_filesize "$CSV_PATH")
    if [[ "$FILE" == "flights" ]] && [[ "$FILE_SIZE" -lt 1073741824 ]]; then
        echo -e "${RED}flights.csv too small. Deleting.${NC}"; rm -f "$CSV_PATH"; exit 1
    fi
done

# 2a. Columnstore Load (optional)
if [[ "$USE_COLUMNSTORE" -eq 1 ]]; then
    echo
    echo -e "${BLUE}Creating '${CS_DB_NAME}' schema...${NC}"
    if ! "$MARIADB_BIN" "${CONN_FLAGS[@]}" < "${SCHEMA_DIR}/columnstore_schema.sql"; then
        echo -e "${RED}Failed to create ${CS_DB_NAME} schema.${NC}"; exit 1
    fi
    for CSV_FILE in airports airlines flights; do
        CS_LOAD_START=$(date +%s)
        echo -ne "Loading ${CSV_FILE}.csv into ${CS_DB_NAME} via cpimport... "
        if ! "$CPIMPORT_BIN" -m 1 -s ',' -E '"' "$CS_DB_NAME" "$CSV_FILE" -l "${SCHEMA_DIR}/${CSV_FILE}.csv" >/dev/null; then
            echo -e "${RED}fail${NC}"; exit 1
        fi
        echo -e "${GREEN}done${NC} ($(elapsed "$CS_LOAD_START"))"
    done
fi

# 3. Sequential Load for Small Tables
for TABLE in airports airlines; do
    CSV_PATH="${SCHEMA_DIR}/${TABLE}.csv"
    ROWS=$(wc -l < "$CSV_PATH" | tr -d ' ')
    LOAD_START=$(date +%s)
    echo -ne "Loading ${TABLE}.csv (${ROWS} lines, $(format_bytes "$(get_filesize "$CSV_PATH")"))... "
    if retry "${TABLE} load" load_small_table "$TABLE"; then
        echo -e "${GREEN}done${NC} ($(elapsed "$LOAD_START"))"
    else
        echo -e "${RED}failed after ${MAX_RETRIES} attempts${NC}"
        exit 1
    fi
done

# Configuration
TOTAL_ROWS=$(wc -l < "${SCHEMA_DIR}/flights.csv" | tr -d ' ')
DATA_ROWS=$(( TOTAL_ROWS - 1 )) # exclude header
LINES_PER_CHUNK=$(( (DATA_ROWS + NUM_CHUNKS - 1) / NUM_CHUNKS ))
FLIGHTS_SIZE=$(get_filesize "${SCHEMA_DIR}/flights.csv")

echo
echo -e "${BLUE}Pre-splitting flights.csv (${TOTAL_ROWS} rows, $(format_bytes "$FLIGHTS_SIZE")) into ${NUM_CHUNKS} chunks of up to ${YELLOW}${LINES_PER_CHUNK} rows${BLUE}...${NC}"
SPLIT_START=$(date +%s)
rm -rf "$TMP_SPLIT_DIR"
mkdir -p "$TMP_SPLIT_DIR"
# Strip header before splitting so no chunk carries the column-name row.
tail -n +2 "${SCHEMA_DIR}/flights.csv" | split -l "$LINES_PER_CHUNK" - "${TMP_SPLIT_DIR}/chunk_"
mapfile -t CHUNK_FILES < <(ls "${TMP_SPLIT_DIR}"/chunk_*)
ACTUAL_CHUNKS=${#CHUNK_FILES[@]}
echo -e "${GREEN}Split complete${NC} (${ACTUAL_CHUNKS} files, $(elapsed "$SPLIT_START"))"
echo -e "${BLUE}Loading ${ACTUAL_CHUNKS} chunks with up to ${MAX_PARALLEL} parallel workers...${NC}"

# Per-chunk failure log: subshells append a line here when a chunk gives up after retries.
FAIL_LOG=$(mktemp)
trap 'rm -f "$FAIL_LOG"' EXIT

for (( i=0; i<ACTUAL_CHUNKS; i++ )); do
    CHUNK_FILE="${CHUNK_FILES[i]}"
    CHUNK_NAME=$(basename "$CHUNK_FILE")
    CHUNK_NUM=$(( i + 1 ))

    (
        CHUNK_START=$(date +%s)
        echo -e "${YELLOW}Starting flights chunk ${CHUNK_NUM}/${ACTUAL_CHUNKS} (${CHUNK_NAME}, $(format_bytes "$(get_filesize "$CHUNK_FILE")"))${NC}"
        if retry "chunk ${CHUNK_NUM}/${ACTUAL_CHUNKS}" load_flights_chunk "$CHUNK_FILE"; then
            echo -e "${GREEN}Finished flights chunk ${CHUNK_NUM}/${ACTUAL_CHUNKS}${NC} ($(elapsed "$CHUNK_START"))"
        else
            echo -e "${RED}Chunk ${CHUNK_NUM}/${ACTUAL_CHUNKS} (${CHUNK_NAME}) failed after ${MAX_RETRIES} attempts${NC}"
            echo "${CHUNK_NUM} ${CHUNK_NAME}" >> "$FAIL_LOG"
        fi
    ) &

    # Throttle to MAX_PARALLEL concurrent subshells. `while` (not `if`) handles
    # the case where multiple subshells finish in close succession: wait -n only
    # reaps one per call, but the loop re-checks the live count each iteration.
    while (( $(jobs -r | wc -l) >= MAX_PARALLEL )); do
        wait -n || true
    done
done
wait

if [[ -s "$FAIL_LOG" ]]; then
    FAILED_COUNT=$(wc -l < "$FAIL_LOG" | tr -d ' ')
    echo -e "${RED}${FAILED_COUNT} chunk(s) failed after ${MAX_RETRIES} retries:${NC}"
    while read -r CN CNAME; do
        echo -e "  chunk ${CN}: ${CNAME}"
    done < "$FAIL_LOG"
    echo -e "${YELLOW}Hint: lower MAX_PARALLEL (currently ${MAX_PARALLEL}) and/or increase NUM_CHUNKS (currently ${NUM_CHUNKS}) and rerun.${NC}"
    echo -e "${YELLOW}Note: the script is idempotent for schema (DROP+CREATE) but NOT for chunked data — partial chunks may have rolled back, but successful chunks remain. Truncate \`${DB_NAME}.flights\` before rerunning to avoid duplicates.${NC}"
    exit 1
fi

echo -e "${GREEN}Parallel load for flights.csv complete.${NC}"

# 5. Cleanup
rm -rf "$TMP_SPLIT_DIR"

